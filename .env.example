# ------------------------------
# 平台选择与通用运行
# ------------------------------

# 可选：Codex 默认工作目录（建议放到 Documents）
CODEX_PROJECT_DIR=~/Documents/CodexBridgeWorkspace

# 可选：聊天上下文保留轮次（每轮=用户+助手，默认 12）
# CHAT_MAX_TURNS=12

# ------------------------------
# Telegram
# ------------------------------

# Telegram Bot Token（来自 @BotFather）
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# 可选：限制仅特定 Telegram 用户可用（填数字 user_id，多用户逗号分隔）
# ALLOWED_USER_IDS=123456789,987654321

# 可选：Telegram 走本地代理（例如 Clash）
# TELEGRAM_PROXY_URL=http://127.0.0.1:7897

# 可选：睡眠唤醒后轮询自恢复检测（秒）
# TELEGRAM_WAKE_WATCHDOG_INTERVAL_SEC=20
# TELEGRAM_WAKE_GAP_THRESHOLD_SEC=90

# 可选：轮询恢复分层阈值（默认 3 次网络错触发重启，5 分钟窗口最多 4 次重启）
# TELEGRAM_POLLING_RESTART_THRESHOLD=3
# TELEGRAM_POLLING_RESTART_COOLDOWN_SEC=20
# TELEGRAM_POLLING_MAX_RESTARTS_PER_WINDOW=4
# TELEGRAM_POLLING_RESTART_WINDOW_SEC=300
# TELEGRAM_ESCALATE_EXIT_CODE=75

# ------------------------------
# 飞书
# ------------------------------

# 飞书私聊入口（首版仅支持私聊文本）
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# ------------------------------
# Codex 与日志
# ------------------------------

# 可选：指定本机 codex 可执行文件路径
# CODEX_BIN=/opt/homebrew/bin/codex

# 可选：指定 codex 模型；留空则走你本机 codex 默认配置
# 建议使用小写模型 ID（如 gpt-5.4、gpt-5.1-codex-mini）
# CODEX_MODEL=gpt-5-codex

# 可选：给 /models 展示可选模型（逗号分隔）；不配置则 /models 允许直接设置任意模型名
# CODEX_ALLOWED_MODELS=gpt-5.4,gpt-5-codex,o3

# 可选：默认推理等级（none/minimal/low/medium/high/xhigh）
# CODEX_REASONING_EFFORT=medium

# 可选：codex 超时
CODEX_TIMEOUT_SEC=600

# 可选：codex 执行权限
CODEX_SANDBOX=danger-full-access

# 可选：日志轮转（默认保留 5 个文件，每个 5MB）
# BOT_LOG_FILE=bot.log
# BOT_LOG_MAX_BYTES=5242880
# BOT_LOG_BACKUP_COUNT=5
# BOT_LOG_TO_STDOUT=1
